        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Lo que se mide, mejora. — Peter Drucker"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ciò che si misura migliora. — Peter Drucker"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wat gemeten wordt, verbetert. — Peter Drucker"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Co się mierzy, to się poprawia. — Peter Drucker"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Det som mäts blir bättre. — Peter Drucker"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O que é medido melhora. — Peter Drucker"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ölçülen şey gelişir. — Peter Drucker"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Что измеряется, то улучшается. — Питер Друкер"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "測定できるものは改善できる。— ピーター・ドラッカー"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "측정할 수 있는 것은 개선된다. — 피터 드러커"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "可衡量者方能改进。— 彼得·德鲁克"
          }
        }
      }
    },
    "Chaque minute compte — utilisez-les avec intention.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Every minute counts — use them with intention."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Jede Minute zählt – nutze sie bewusst."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cada minuto cuenta: úsalos con intención."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ogni minuto conta: usali con intenzione."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Elke minuut telt — gebruik ze bewust."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Każda minuta się liczy — wykorzystaj je świadomie."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Varje minut räknas — använd dem med avsikt."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Cada minuto conta — use-os com intenção."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Her dakika değerlidir — bilinçli kullanın."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Каждая минута на счету — используйте их осознанно."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "1分1秒が大切 — 意図を持って使いましょう。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "1분 1초가 소중합니다 — 의도를 가지고 사용하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "每一分钟都很宝贵——请有目的地使用它们。"
          }
        }
      }
    },
    "Commencez là où vous êtes. Utilisez ce que vous avez. Faites ce que vous pouvez. — Arthur Ashe": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Start where you are. Use what you have. Do what you can. — Arthur Ashe"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fang dort an, wo du bist. Nutze, was du hast. Tu, was du kannst. — Arthur Ashe"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Empieza donde estás. Usa lo que tienes. Haz lo que puedas. — Arthur Ashe"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Inizia da dove sei. Usa ciò che hai. Fai ciò che puoi. — Arthur Ashe"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Begin waar je bent. Gebruik wat je hebt. Doe wat je kunt. — Arthur Ashe"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zacznij tam, gdzie jesteś. Użyj tego, co masz. Zrób to, co możesz. — Arthur Ashe"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Börja där du är. Använd det du har. Gör det du kan. — Arthur Ashe"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Comece de onde você está. Use o que você tem. Faça o que você pode. — Arthur Ashe"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bulunduğun yerden başla. Elindekini kullan. Yapabildiğini yap. — Arthur Ashe"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Начни с того места, где ты есть. Используй то, что имеешь. Делай, что можешь. — Артур Эш"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "今いる場所から始めよう。持っているものを使おう。できることをしよう。— アーサー・アッシュ"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "당신이 있는 곳에서 시작하세요. 가진 것을 활용하세요. 할 수 있는 것을 하세요. — 아서 애시"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "从你所在之处开始。用你所拥有的。做你能做的。— 亚瑟·阿什"
          }
        }
      }
    },
