        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Het geheim van verandering: richt je energie op het creëren van het nieuwe."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Sekret zmiany: skup energię na tworzeniu nowego."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Förändringens hemlighet: rikta din energi mot att skapa det nya."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O segredo da mudança: concentrar sua energia na criação do novo."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Değişimin sırrı: enerjini yeniyi yaratmaya odaklamak."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Секрет перемен: направить энергию на создание нового."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "変化の秘訣は、新しいものを創ることにエネルギーを注ぐこと。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "변화의 비결: 새로운 것을 만드는 데 에너지를 집중하는 것."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "改变的秘诀：集中精力去创造新事物。"
          }
        }
      }
    },
    "Le succès est la somme de petits efforts répétés jour après jour. — Robert Collier": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Success is the sum of small efforts repeated day after day. — Robert Collier"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erfolg ist die Summe kleiner Anstrengungen, Tag für Tag wiederholt. — Robert Collier"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El éxito es la suma de pequeños esfuerzos repetidos día tras día. — Robert Collier"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il successo è la somma di piccoli sforzi ripetuti giorno dopo giorno. — Robert Collier"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Succes is de som van kleine inspanningen die dag na dag worden herhaald. — Robert Collier"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Sukces to suma małych wysiłków powtarzanych dzień po dniu. — Robert Collier"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Framgång är summan av små ansträngningar som upprepas dag efter dag. — Robert Collier"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O sucesso é a soma de pequenos esforços repetidos dia após dia. — Robert Collier"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Başarı, gün be gün tekrarlanan küçük çabaların toplamıdır. — Robert Collier"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Успех — это сумма маленьких усилий, повторяемых изо дня в день. — Роберт Кольер"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "成功とは、日々繰り返される小さな努力の積み重ねである。— ロバート・コリアー"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "성공은 날마다 반복된 작은 노력의 합이다. — 로버트 콜리어"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "成功是日复一日重复的小努力之和。— 罗伯特·科利尔"
          }
        }
      }
    },
    "Le talent gagne des matchs, mais le travail d'équipe gagne des championnats. — Jordan": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Talent wins games, but teamwork wins championships. — Jordan"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Talent gewinnt Spiele, aber Teamwork gewinnt Meisterschaften. — Jordan"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El talento gana partidos, pero el trabajo en equipo gana campeonatos. — Jordan"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il talento vince le partite, ma il gioco di squadra vince i campionati. — Jordan"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Talent wint wedstrijden, maar teamwork wint kampioenschappen. — Jordan"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Talent wygrywa mecze, ale praca zespołowa wygrywa mistrzostwa. — Jordan"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Talang vinner matcher, men lagarbete vinner mästerskap. — Jordan"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O talento ganha jogos, mas o trabalho em equipe ganha campeonatos. — Jordan"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yetenek maç kazandırır, ama takım oyunu şampiyonluk kazandırır. — Jordan"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Талант выигрывает матчи, а командная работа — чемпионаты. — Джордан"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "才能は試合に勝ち、チームワークは優勝を勝ち取る。— ジョーダン"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "재능은 경기를 이기고, 팀워크는 우승을 이긴다. — 조던"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "天赋赢得比赛，团队赢得冠军。— 乔丹"
          }
        }
      }
    },
    "Le temps est la ressource la plus précieuse — investissez-le judicieusement.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Time is the most precious resource — invest it wisely."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zeit ist die wertvollste Ressource – investiere sie klug."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El tiempo es el recurso más valioso: inviértelo con criterio."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il tempo è la risorsa più preziosa: investilo con saggezza."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Tijd is de kostbaarste hulpbron — investeer hem verstandig."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Czas to najcenniejszy zasób — inwestuj go mądrze."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Tid är den mest värdefulla resursen — investera den klokt."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O tempo é o recurso mais precioso — invista-o com sabedoria."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Zaman en değerli kaynaktır — onu akıllıca değerlendirin."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Время — самый ценный ресурс, вкладывайте его мудро."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "時間は最も貴重な資源 — 賢く投資しましょう。"
