            "value": "Verimlilik daha çok yapmak değil, daha iyi yapmaktır."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Продуктивность — это не делать больше, а делать лучше."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "生産性とは、多くやることではなく、より良くやること。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
