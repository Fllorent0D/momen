    "Concentrez-vous sur l'essentiel et éliminez le superflu.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Focus on the essential and eliminate the superfluous."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Konzentriere dich aufs Wesentliche und lass Überflüssiges weg."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Concéntrate en lo esencial y elimina lo superfluo."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Concentrati sull'essenziale ed elimina il superfluo."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Focus op het essentiële en schrap het overbodige."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Skup się na tym, co istotne, i wyeliminuj zbędne."
