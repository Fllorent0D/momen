          "stringUnit": {
            "state": "translated",
            "value": "Um pequeno passo por dia leva a grandes resultados."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Her gün atılan küçük bir adım büyük sonuçlara götürür."
