    "Un bon standup, c'est 15 minutes qui en sauvent 8 heures.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A good standup is 15 minutes that save 8 hours."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ein guter Standup: 15 Minuten, die 8 Stunden sparen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Un buen standup son 15 minutos que ahorran 8 horas."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Un buon standup sono 15 minuti che ne fanno risparmiare 8 ore."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Een goede standup is 15 minuten die 8 uur besparen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dobry standup to 15 minut, które oszczędzają 8 godzin."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "En bra standup är 15 minuter som sparar 8 timmar."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Um bom standup são 15 minutos que economizam 8 horas."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "İyi bir standup, 8 saati kurtaran 15 dakikadır."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Хороший стендап — это 15 минут, которые экономят 8 часов."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "良いスタンドアップは、8時間を救う15分。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "좋은 스탠드업은 8시간을 아끼는 15분입니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "一次好的站会，是省下 8 小时的 15 分钟。"
          }
        }
      }
    },
    "Un objectif sans plan n'est qu'un souhait. — Antoine de Saint-Exupéry": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A goal without a plan is just a wish. — Antoine de Saint-Exupéry"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ein Ziel ohne Plan ist nur ein Wunsch. — Antoine de Saint-Exupéry"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Una meta sin un plan es solo un deseo. — Antoine de Saint-Exupéry"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Un obiettivo senza un piano è solo un desiderio. — Antoine de Saint-Exupéry"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Een doel zonder plan is slechts een wens. — Antoine de Saint-Exupéry"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Cel bez planu to tylko życzenie. — Antoine de Saint-Exupéry"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Ett mål utan plan är bara en önskan. — Antoine de Saint-Exupéry"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Um objetivo sem um plano não passa de um desejo. — Antoine de Saint-Exupéry"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Planı olmayan hedef, yalnızca bir dilektir. — Antoine de Saint-Exupéry"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Цель без плана — просто мечта. — Антуан де Сент-Экзюпери"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "計画のない目標は、ただの願いにすぎない。— アントワーヌ・ド・サン＝テグジュペリ"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "계획 없는 목표는 그저 소망일 뿐이다. — 앙투안 드 생텍쥐페리"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "没有计划的目标只是一个愿望。— 安托万·德·圣埃克苏佩里"
          }
        }
      }
    },
    "Un petit pas chaque jour mène à de grands résultats.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A small step each day leads to big results."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ein kleiner Schritt pro Tag führt zu großen Ergebnissen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Un pequeño paso cada día lleva a grandes resultados."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Un piccolo passo ogni giorno porta a grandi risultati."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Elke dag een kleine stap leidt tot grote resultaten."
