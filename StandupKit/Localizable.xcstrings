        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Kreativitet är intelligens som har roligt. — Einstein"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A criatividade é a inteligência se divertindo. — Einstein"
          }
        },
