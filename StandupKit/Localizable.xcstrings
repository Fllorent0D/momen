          "stringUnit": {
            "state": "translated",
            "value": "Er is geen gunstige wind voor wie niet weet waarheen hij vaart. — Seneca"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nie ma pomyślnego wiatru dla tego, kto nie wie, dokąd płynie. — Seneka"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Ingen vind är gynnsam för den som inte vet vart han ska. — Seneca"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Não há vento favorável para o marinheiro que não sabe aonde ir. — Sêneca"
