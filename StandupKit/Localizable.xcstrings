            "value": "Mniej spotkań, więcej działania."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Färre möten, mer handling."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Menos reuniões, mais ação."
