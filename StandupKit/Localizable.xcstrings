    },
    "Ne remettez jamais à demain ce que vous pouvez faire aujourd'hui. — Benjamin Franklin": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Never put off until tomorrow what you can do today. — Benjamin Franklin"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verschiebe nie auf morgen, was du heute tun kannst. — Benjamin Franklin"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Nunca dejes para mañana lo que puedas hacer hoy. — Benjamin Franklin"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Non rimandare mai a domani ciò che puoi fare oggi. — Benjamin Franklin"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Stel nooit uit tot morgen wat je vandaag kunt doen. — Benjamin Franklin"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nigdy nie odkładaj na jutro tego, co możesz zrobić dzisiaj. — Benjamin Franklin"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Skjut aldrig upp till imorgon det du kan göra idag. — Benjamin Franklin"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Nunca deixe para amanhã o que você pode fazer hoje. — Benjamin Franklin"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bugün yapabileceğini asla yarına bırakma. — Benjamin Franklin"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Никогда не откладывай на завтра то, что можешь сделать сегодня. — Бенджамин Франклин"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "今日できることを明日に延ばすな。— ベンジャミン・フランクリン"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "오늘 할 수 있는 일을 내일로 미루지 말라. — 벤저민 프랭클린"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "今日事，今日毕。— 本杰明·富兰克林"
          }
        }
      }
    },
