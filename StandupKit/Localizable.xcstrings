    "Ensemble, nous sommes plus forts que la somme de nos parties.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Together, we are stronger than the sum of our parts."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Gemeinsam sind wir stärker als die Summe unserer Teile."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Juntos somos más fuertes que la suma de nuestras partes."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Insieme siamo più forti della somma delle nostre parti."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Samen zijn we sterker dan de som van onze delen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Razem jesteśmy silniejsi niż suma naszych części."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Tillsammans är vi starkare än summan av våra delar."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Juntos, somos mais fortes que a soma das nossas partes."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Birlikte, parçalarımızın toplamından daha güçlüyüz."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вместе мы сильнее, чем сумма наших частей."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "私たちは一人ひとりの総和よりも、共にいるときの方が強い。"
