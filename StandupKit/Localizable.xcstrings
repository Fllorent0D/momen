    "Debloquez les participants illimites, la personnalisation complete et les statistiques avancees.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Unlock unlimited participants, full customization, and advanced statistics."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Schalte unbegrenzte Teilnehmer, vollständige Anpassung und erweiterte Statistiken frei."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Desbloquea participantes ilimitados, personalización completa y estadísticas avanzadas."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sblocca partecipanti illimitati, personalizzazione completa e statistiche avanzate."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ontgrendel onbeperkte deelnemers, volledige personalisatie en geavanceerde statistieken."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Odblokuj nieograniczoną liczbę uczestników, pełną personalizację i zaawansowane statystyki."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Lås upp obegränsat antal deltagare, full anpassning och avancerad statistik."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Desbloqueie participantes ilimitados, personalização completa e estatísticas avançadas."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sınırsız katılımcı, tam kişiselleştirme ve gelişmiş istatistiklerin kilidini açın."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Разблокируйте неограниченное число участников, полную настройку и расширенную статистику."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "参加者数無制限、フルカスタマイズ、高度な統計を解除しましょう。"
