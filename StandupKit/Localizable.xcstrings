    "Seul on va plus vite, ensemble on va plus loin.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Alone we go faster, together we go further."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Allein geht man schneller, gemeinsam kommt man weiter."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Solo se va más rápido, juntos se llega más lejos."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Da soli si va più veloci, insieme si va più lontano."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Alleen ga je sneller, samen kom je verder."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Sam idziesz szybciej, razem dojdziecie dalej."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Ensam går man snabbare, tillsammans kommer man längre."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Sozinho vamos mais rápido, juntos vamos mais longe."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yalnız daha hızlı gideriz, birlikte daha uzağa."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "В одиночку идёшь быстрее, вместе — дальше."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "一人なら速く、みんなでなら遠くまで。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "혼자면 빨리 가고, 함께면 멀리 간다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "一个人走得快，一群人走得远。"
          }
        }
      }
    },
    "Seuls ceux qui prennent le risque d'échouer spectaculairement réussiront brillamment. — JFK": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Only those who dare to fail greatly can ever achieve greatly. — JFK"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nur wer das Risiko eingeht, spektakulär zu scheitern, kann Großes erreichen. — JFK"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Solo quienes se arriesgan a fracasar estrepitosamente logran triunfar de forma brillante. — JFK"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Solo chi rischia di fallire clamorosamente può riuscire brillantemente. — JFK"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Alleen wie het risico durft te nemen om spectaculair te falen, zal briljant slagen. — JFK"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Tylko ci, którzy ryzykują spektakularną porażkę, mogą osiągnąć wielki sukces. — JFK"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Bara de som vågar misslyckas storslaget kan lyckas briljant. — JFK"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Somente aqueles que ousam falhar grandiosamente podem alcançar a grandeza. — JFK"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yalnızca büyük başarısızlığı göze alanlar büyük başarıya ulaşabilir. — JFK"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Лишь те, кто рискует потерпеть громкое поражение, способны добиться великого. — Дж. Ф. Кеннеди"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "大きく失敗する勇気を持つ者だけが、大きな成功を手にできる。— JFK"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "크게 실패할 위험을 감수하는 자만이 눈부시게 성공한다. — JFK"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "只有敢于轰轰烈烈失败的人，才能取得辉煌的成功。— JFK"
          }
        }
      }
    },
