    "La productivité, ce n'est pas faire plus, c'est faire mieux.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Productivity isn't doing more, it's doing better."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Produktivität heißt nicht mehr tun, sondern besser tun."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La productividad no es hacer más, es hacer mejor."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La produttività non è fare di più, è fare meglio."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Productiviteit is niet meer doen, maar beter doen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Produktywność to nie robienie więcej, lecz robienie lepiej."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Produktivitet handlar inte om att göra mer, utan om att göra bättre."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Produtividade não é fazer mais, é fazer melhor."
          }
        },
        "tr": {
