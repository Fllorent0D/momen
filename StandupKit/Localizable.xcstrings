{
  "sourceLanguage": "fr",
  "strings": {
    "Les achats ne sont pas disponibles sur cet appareil.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "In-app purchases are not available on this device."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "In-App-Käufe sind auf diesem Gerät nicht verfügbar."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las compras no están disponibles en este dispositivo."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Gli acquisti non sono disponibili su questo dispositivo."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Aankopen zijn niet beschikbaar op dit apparaat."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zakupy w aplikacji są niedostępne na tym urządzeniu."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Köp i appen är inte tillgängliga på den här enheten."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "As compras não estão disponíveis neste dispositivo."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Uygulama içi satın almalar bu cihazda kullanılamıyor."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Покупки недоступны на этом устройстве."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このデバイスではアプリ内課金を利用できません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 기기에서는 앱 내 구입을 사용할 수 없습니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此设备不支持应用内购买。"
          }
        }
      }
    },
