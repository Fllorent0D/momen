        }
      }
    },
    "La discipline est le pont entre les objectifs et leur réalisation. — Jim Rohn": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Discipline is the bridge between goals and accomplishment. — Jim Rohn"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Disziplin ist die Brücke zwischen Zielen und Erfolg. — Jim Rohn"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La disciplina es el puente entre las metas y los logros. — Jim Rohn"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La disciplina è il ponte tra gli obiettivi e la loro realizzazione. — Jim Rohn"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Discipline is de brug tussen doelen en verwezenlijking. — Jim Rohn"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dyscyplina to most między celami a ich realizacją. — Jim Rohn"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Disciplin är bron mellan mål och förverkligande. — Jim Rohn"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A disciplina é a ponte entre os objetivos e sua realização. — Jim Rohn"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Disiplin, hedeflerle başarı arasındaki köprüdür. — Jim Rohn"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Дисциплина — это мост между целями и их достижением. — Джим Рон"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "規律は目標と達成をつなぐ橋である。— ジム・ローン"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "규율은 목표와 성취를 잇는 다리다. — 짐 론"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "自律是连接目标与成就的桥梁。— 吉姆·罗恩"
          }
        }
      }
    },
    "La meilleure façon de prédire l'avenir, c'est de le créer. — Peter Drucker": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The best way to predict the future is to create it. — Peter Drucker"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die beste Art, die Zukunft vorherzusagen, ist, sie zu gestalten. — Peter Drucker"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La mejor manera de predecir el futuro es crearlo. — Peter Drucker"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il modo migliore per prevedere il futuro è crearlo. — Peter Drucker"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De beste manier om de toekomst te voorspellen is haar te creëren. — Peter Drucker"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Najlepszym sposobem przewidywania przyszłości jest jej tworzenie. — Peter Drucker"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Bästa sättet att förutsäga framtiden är att skapa den. — Peter Drucker"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A melhor maneira de prever o futuro é criá-lo. — Peter Drucker"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Geleceği tahmin etmenin en iyi yolu onu yaratmaktır. — Peter Drucker"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Лучший способ предсказать будущее — создать его. — Питер Друкер"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "未来を予測する最善の方法は、それを創ることだ。— ピーター・ドラッカー"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "미래를 예측하는 최선의 방법은 미래를 만드는 것이다. — 피터 드러커"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "预测未来的最好方法就是创造未来。— 彼得·德鲁克"
          }
        }
      }
    },
