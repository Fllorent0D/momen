# Métadonnées App Store (fastlane deliver / upload_to_app_store).
# Les textes vivent dans fastlane/metadata/<locale>/*.txt (générés depuis docs/).
# Les captures dans fastlane/screenshots/<locale>/ (produites par snapshot).

app_identifier "be.floca.standup-timer"

# Ne pas écraser la note de version / prix par erreur.
submit_for_review false
automatic_release false

# Precheck désactivé : il ne supporte pas la vérif des achats intégrés avec une
# clé App Store Connect API (nécessiterait un login Apple ID). On ne soumet pas
# automatiquement (submit_for_review false) → la revue Apple fait foi.
run_precheck_before_submit false
