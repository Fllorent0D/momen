# Copie ce fichier en `.env` (gitignored) et remplis-le.
# App Store Connect API key : App Store Connect → Users and Access → Integrations → API keys
ASC_KEY_ID=XXXXXXXXXX
ASC_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ASC_KEY_PATH=fastlane/AuthKey_XXXXXXXXXX.p8

# Optionnel (sinon déduits) :
FASTLANE_APPLE_ID=florent@floca.be
FASTLANE_ITC_TEAM_ID=
