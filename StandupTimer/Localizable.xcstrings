    "Il faut au moins 2 réunions pour voir les tendances.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "At least 2 meetings are needed to see trends."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Für Trends sind mindestens 2 Meetings nötig."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se necesitan al menos 2 reuniones para ver las tendencias."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Servono almeno 2 riunioni per vedere le tendenze."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Er zijn minstens 2 vergaderingen nodig om trends te zien."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Potrzeba co najmniej 2 spotkań, aby zobaczyć trendy."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Minst 2 möten krävs för att se trender."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "São necessárias pelo menos 2 reuniões para ver as tendências."
          }
        },
