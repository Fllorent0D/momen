    "Free est limité à 4 participants. Retirez-en un ou passez à Pro.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Free is limited to 4 participants. Remove one or upgrade to Pro."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Free ist auf 4 Teilnehmer begrenzt. Entferne einen oder wechsle zu Pro."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Free está limitado a 4 participantes. Quita uno o pásate a Pro."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Free è limitato a 4 partecipanti. Rimuovine uno o passa a Pro."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Free is beperkt tot 4 deelnemers. Verwijder er een of ga over naar Pro."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Free jest ograniczone do 4 uczestników. Usuń jednego lub przejdź na Pro."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Free är begränsat till 4 deltagare. Ta bort en eller uppgradera till Pro."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O Free é limitado a 4 participantes. Remova um ou assine o Pro."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Free 4 katılımcıyla sınırlıdır. Birini çıkarın veya Pro'ya geçin."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Free ограничен 4 участниками. Удалите одного или перейдите на Pro."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Freeは4人までです。1人減らすか、Proへアップグレードしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Free는 참가자 4명으로 제한됩니다. 한 명을 빼거나 Pro로 업그레이드하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Free 限 4 位参与者。请移除一位或升级到 Pro。"
          }
        }
      }
    },
