    "Les raccourcis fonctionnent quand la fenêtre Momen est au premier plan.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Shortcuts work when the Momen window is in the foreground."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Tastenkürzel funktionieren, wenn das Momen-Fenster im Vordergrund ist."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los atajos funcionan cuando la ventana de Momen está en primer plano."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le scorciatoie funzionano quando la finestra di Momen è in primo piano."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Sneltoetsen werken wanneer het Momen-venster op de voorgrond is."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Skróty działają, gdy okno Momen jest na pierwszym planie."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Genvägar fungerar när Momen-fönstret är i förgrunden."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Os atalhos funcionam quando a janela do Momen está em primeiro plano."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kısayollar, Momen penceresi ön plandayken çalışır."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сочетания клавиш работают, когда окно Momen активно."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ショートカットはMomenのウィンドウが最前面にあるときに機能します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "단축키는 Momen 창이 맨 앞에 있을 때 작동합니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "快捷键在 Momen 窗口位于前台时生效。"
          }
        }
      }
    },
    "Momen est gratuit jusqu'a 4 participants.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Momen is free for up to 4 participants."
