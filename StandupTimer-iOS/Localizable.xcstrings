    "Débloquez Pro une fois pour toutes et gardez l'accès à vie.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Unlock Pro once and keep access for life."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Schalte Pro ein für alle Mal frei und behalte lebenslangen Zugriff."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Desbloquea Pro de una vez y conserva el acceso de por vida."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sblocca Pro una volta per tutte e mantieni l'accesso a vita."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ontgrendel Pro voorgoed en behoud levenslang toegang."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Odblokuj Pro raz na zawsze i zachowaj dostęp na całe życie."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Lås upp Pro en gång för alla och behåll livstidsåtkomst."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Desbloqueie o Pro de uma vez e mantenha o acesso para sempre."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pro'yu bir kez açın ve erişimi ömür boyu koruyun."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Разблокируйте Pro один раз и сохраните доступ навсегда."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Proを一度解除すれば、永久にアクセスできます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Pro를 한 번만 잠금 해제하면 평생 이용할 수 있습니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "一次性解锁 Pro，永久使用。"
          }
        }
      }
    },
