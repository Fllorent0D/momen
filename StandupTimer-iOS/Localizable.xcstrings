          "stringUnit": {
            "state": "translated",
            "value": "Ditt engångsköp i appen återställs automatiskt via App Store."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Sua compra única no app é restaurada automaticamente pela App Store."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tek seferlik uygulama içi satın alımınız App Store üzerinden otomatik olarak geri yüklenir."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ваша разовая покупка автоматически восстанавливается через App Store."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "買い切りのアプリ内課金はApp Store経由で自動的に復元されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "일회성 앱 내 구입은 App Store를 통해 자동으로 복원됩니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你的一次性应用内购买将通过 App Store 自动恢复。"
          }
        }
      }
    },
